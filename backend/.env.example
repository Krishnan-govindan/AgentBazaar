# ── Nevermined ────────────────────────────────────────────────
# Get from nevermined.app → Settings → API Keys
# Use "sandbox:" prefix for hackathon/testing
NVM_API_KEY=sandbox:your-nevermined-api-key
NVM_ENVIRONMENT=sandbox

# Set these AFTER running register_agents.py (all 3 agents)
NVM_PLAN_ID_VALIDATOR=
NVM_PLAN_ID_RESEARCH=
NVM_AGENT_ID_VALIDATOR=
NVM_AGENT_ID_RESEARCH=
NVM_AGENT_ID_DIRECTORY=

# Future Proposals agent ($1.00/call) — registered by register_agents.py
NVM_PLAN_ID_FUTURE=
NVM_AGENT_ID_FUTURE=

# Marketing/Promotions agent ($0.75/call) — registered by register_agents.py
NVM_PLAN_ID_PROMOTE=
NVM_AGENT_ID_PROMOTE=

# Legacy: kept for backward compatibility (maps to NVM_PLAN_ID_VALIDATOR if set)
# NVM_PLAN_ID=
# NVM_AGENT_ID=

# ── ZeroClick AI-native ads ───────────────────────────────────
# Get from developer.zeroclick.ai → App API Keys → Create API Key
ZEROCLICK_API_KEY=your-zeroclick-api-key

# ── Apify ─────────────────────────────────────────────────────
# Get from apify.com → Settings → Integrations → API token
APIFY_TOKEN=your-apify-token

# ── Exa ───────────────────────────────────────────────────────
# Get from dashboard.exa.ai (1000 free requests/month on free plan)
EXA_API_KEY=your-exa-api-key

# ── Anthropic ─────────────────────────────────────────────────
# Get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key

# ── Supabase ──────────────────────────────────────────────────
# Get from supabase.com → your project → Settings → API
# Use SERVICE ROLE key (not anon) so we can write to all tables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Deployment ────────────────────────────────────────────────
# Set to your Railway URL after deploying, then re-run register_agents.py
BACKEND_URL=https://your-app.up.railway.app
PORT=8000

# ── Optional ──────────────────────────────────────────────────
# Your wallet address for receiving Nevermined payments
BUILDER_ADDRESS=0xYourWalletAddress
